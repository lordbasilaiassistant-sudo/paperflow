# Any OpenAI-compatible endpoint works. Tested with z.ai's free GLM flash tier.
LLM_BASE_URL=https://api.z.ai/api/paas/v4
LLM_API_KEY=your-key-here
LLM_MODEL=glm-4.5-flash

# Provider-specific extras merged into every chat request (JSON).
# For z.ai GLM-4.5 models this disables reasoning tokens (~3x faster, fewer tokens):
LLM_EXTRA_BODY={"thinking": {"type": "disabled"}}

# Optional: reference pricing used for cost/doc reporting (USD per 1M tokens).
# Defaults to 0 (glm-4.5-flash is free). Set these to model list prices to see real cost math.
LLM_PRICE_INPUT_PER_M=0
LLM_PRICE_OUTPUT_PER_M=0

# Docs scoring at or above this confidence (and passing validation) are auto-accepted;
# everything else routes to the human review queue.
ROUTE_THRESHOLD=0.80

# Path to the tesseract binary if it is not on PATH (Windows default shown).
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# Where uploads, rendered page images, and the SQLite db live.
DATA_DIR=data
